{
  "name": "ai-investment-assistant-server",
  "version": "1.0.0",
  "description": "投资喵 - AI智能投资陪伴助手 - 后端服务",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && node scripts/copyBuildAssets.cjs",
    "start": "node dist/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "db:init": "ts-node src/db/init.ts",
    "valuation:refresh": "ts-node src/scripts/refreshValuationCache.ts",
    "snapshots:refresh": "ts-node src/scripts/refreshPortfolioSnapshots.ts"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "fast-check": "^3.23.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [],
