PORT=3000
DB_PATH=./data/app.db
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# --- 生产 HTTPS / CORS / 代理 ---
# 公网生产务必使用 HTTPS，避免 JWT 在传输中被窃听。
# CORS：NODE_ENV=production 时生效。多个前端 Origin 用英文逗号分隔，例如：
#   CORS_ORIGINS=https://tz.example.com,https://www.tz.example.com
# 留空表示不向其它域返回 CORS 头（网页与 API 同域部署时一般无需配置）。
CORS_ORIGINS=
# 置于 Nginx 等反向代理之后时设为 1，以便限流按真实客户端 IP 统计（X-Forwarded-For）。
TRUST_PROXY=

# --- 安全说明（SSE）---
# EventSource 无法自定义 Header，行情 SSE 使用查询参数 ?token=JWT。
# 生产环境请勿在访问日志中记录完整 URL 查询串；长期可改为短效 SSE 票据。

# AI Provider API Keys
DEEPSEEK_API_KEY=your-deepseek-api-key
# DeepSeek 模型选择: deepseek-chat (V3, 快速) 或 deepseek-reasoner (R1, 推理)
DEEPSEEK_MODEL=deepseek-chat
CLAUDE_API_KEY=your-claude-api-key
QWEN_API_KEY=your-qwen-api-key
